<?xml version="1.0" encoding="utf-8"?>
<robot name="simple_arm">
  <!-- world / base -->
  <link name="world"/>
  <link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry><box size="0.1 0.1 0.1"/></geometry>
    </visual>
    <collision>
      <geometry><box size="0.1 0.1 0.1"/></geometry>
    </collision>
  </link>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- joint1: revolute -->
  <link name="link1">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.0005"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.04" length="0.2"/></geometry>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.2"/></geometry>
    </collision>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="50.0" velocity="3.0"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <!-- joint2: revolute -->
  <link name="link2">
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0.15 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.003"/>
    </inertial>
    <visual>
      <geometry><box size="0.3 0.04 0.04"/></geometry>
    </visual>
    <collision>
      <geometry><box size="0.3 0.04 0.04"/></geometry>
    </collision>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.2" rpy="0 1.5708 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="30.0" velocity="2.0"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <!-- tool frame (no geometry) -->
  <link name="tool0"/>
  <joint name="joint2_to_tool" type="fixed">
    <parent link="link2"/>
    <child link="tool0"/>
    <origin xyz="0.3 0 0" rpy="0 0 0"/>
  </joint>

  <!-- gripper finger (prismatic, not in arm cspace) -->
  <link name="finger_link">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.000005"/>
    </inertial>
    <visual>
      <geometry><box size="0.01 0.02 0.04"/></geometry>
    </visual>
    <collision>
      <geometry><box size="0.01 0.02 0.04"/></geometry>
    </collision>
  </link>

  <joint name="finger_joint" type="prismatic">
    <parent link="tool0"/>
    <child link="finger_link"/>
    <origin xyz="0 0.02 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0.04" effort="5.0" velocity="0.5"/>
  </joint>
</robot>
